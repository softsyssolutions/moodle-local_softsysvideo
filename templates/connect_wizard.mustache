{{!
    Template: local_softsysvideo/connect_wizard
    Standard Moodle form (no AJAX) — avoids Slim router 404 on POST to local plugin files.
    Two states: connected / not connected
}}
<div class="local-softsysvideo-connect container py-4" style="max-width:640px">

  {{#message}}
  <div class="alert alert-{{message_type}} alert-dismissible fade show" role="alert">
    {{{message}}}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  {{/message}}

  {{#is_connected}}
  {{! ── ESTADO: CONECTADO ──────────────────────────────────────── }}
  <div class="card shadow-sm border-success mb-4">
    <div class="card-header bg-success text-white d-flex align-items-center gap-2">
      <span class="fs-5">✅</span>
      <strong>Conectado a SoftSys Video</strong>
    </div>
    <div class="card-body">
      <dl class="row mb-3">
        {{#tenant_name}}
        <dt class="col-sm-4">Organización</dt>
        <dd class="col-sm-8"><strong>{{tenant_name}}</strong></dd>
        {{/tenant_name}}
        {{#credit_balance}}
        <dt class="col-sm-4">Saldo</dt>
        <dd class="col-sm-8">
          <span class="fw-bold text-success">${{credit_balance}} USD</span>
        </dd>
        {{/credit_balance}}
        {{#api_url}}
        <dt class="col-sm-4">API URL</dt>
        <dd class="col-sm-8"><code class="small">{{api_url}}</code></dd>
        {{/api_url}}
      </dl>

      <div class="d-flex flex-wrap gap-2">
        <a href="{{wwwroot}}/local/softsysvideo/setup.php"
           class="btn btn-outline-primary">⚙️ Setup Wizard</a>

        <form method="post" action="{{wwwroot}}/local/softsysvideo/setup.php" class="d-inline">
          <input type="hidden" name="action" value="configure_bbb"/>
          <input type="hidden" name="sesskey" value="{{sesskey}}"/>
          <button type="submit" class="btn btn-success">🔗 Configurar BigBlueButton</button>
        </form>

        <form method="post" action="{{wwwroot}}/local/softsysvideo/connect.php" class="d-inline"
              onsubmit="return confirm('¿Desconectar este Moodle de SoftSys Video?');">
          <input type="hidden" name="action" value="disconnect"/>
          <input type="hidden" name="sesskey" value="{{sesskey}}"/>
          <button type="submit" class="btn btn-outline-danger">🔌 Desconectar</button>
        </form>
      </div>
    </div>
  </div>
  {{/is_connected}}

  {{^is_connected}}
  {{! ── ESTADO: NO CONECTADO ───────────────────────────────────── }}
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-light">
      <h5 class="mb-0">🔌 Conectar con SoftSys Video</h5>
    </div>
    <div class="card-body">
      <p class="text-muted">
        Ingresa las credenciales de tu cuenta en
        <a href="https://app.softsysvideo.com" target="_blank">app.softsysvideo.com</a>
        para conectar este Moodle automáticamente.
      </p>

      <form method="post" action="{{wwwroot}}/local/softsysvideo/connect.php">
        <input type="hidden" name="action" value="connect"/>
        <input type="hidden" name="sesskey" value="{{sesskey}}"/>

        <div class="mb-3">
          <label for="ssv-email" class="form-label fw-semibold">
            Email de tu cuenta SoftSys Video <span class="text-danger">*</span>
          </label>
          <input type="email" id="ssv-email" name="email" class="form-control"
                 placeholder="admin@tuorganizacion.com" autocomplete="email" required/>
        </div>

        <div class="mb-3">
          <label for="ssv-password" class="form-label fw-semibold">
            Contraseña (o Shared Secret) <span class="text-danger">*</span>
          </label>
          <input type="password" id="ssv-password" name="password" class="form-control"
                 autocomplete="current-password" required/>
          <div class="form-text">
            Usa la contraseña de tu cuenta, o el Shared Secret que encuentras en
            <a href="https://app.softsysvideo.com/settings" target="_blank">Settings → Moodle Integration</a>.
          </div>
        </div>

        {{#bbb_installed}}
        <div class="form-check mb-3">
          <input class="form-check-input" type="checkbox" id="ssv-configure-bbb"
                 name="configure_bbb" value="1" checked/>
          <label class="form-check-label" for="ssv-configure-bbb">
            Configurar BigBlueButton automáticamente al conectar
          </label>
        </div>
        {{/bbb_installed}}

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary px-4">
            🔌 Conectar
          </button>
          <a href="{{wwwroot}}/admin/settings.php?section=local_softsysvideo"
             class="btn btn-outline-secondary">Cancelar</a>
        </div>
      </form>
    </div>
  </div>

  <div class="card border-0 bg-light">
    <div class="card-body small text-muted">
      <strong>¿Cómo funciona?</strong>
      <ol class="mt-1 mb-0 ps-3">
        <li>Introduces tus credenciales de SoftSys Video</li>
        <li>El sistema obtiene automáticamente tu API URL, Plugin Key y Shared Secret</li>
        <li>BigBlueButton se configura para usar SoftSys Video</li>
        <li>Tus credenciales <strong>no se almacenan</strong> — solo el token de acceso</li>
      </ol>
    </div>
  </div>
  {{/is_connected}}

</div>
