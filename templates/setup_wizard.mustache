<div class="local-softsysvideo-setup">
    <div class="alert {{statusclass}}" role="status">
        <strong>{{#str}}status, local_softsysvideo{{/str}}:</strong> {{statuslabel}}<br>
        <span>{{statusmessage}}</span>
    </div>

    <form id="local-softsysvideo-setup-form" class="mform">
        <input type="hidden" id="softsysvideo-sesskey" value="{{sesskey}}">

        <div class="mb-3">
            <label class="form-label" for="softsysvideo-api-url">{{#str}}api_url, local_softsysvideo{{/str}}</label>
            <input class="form-control" id="softsysvideo-api-url" type="url" value="{{apiurl}}" required>
            <div class="form-text">{{#str}}api_url_help, local_softsysvideo{{/str}}</div>
        </div>

        <div class="mb-3">
            <label class="form-label" for="softsysvideo-plugin-key">{{#str}}plugin_key, local_softsysvideo{{/str}}</label>
            <input class="form-control" id="softsysvideo-plugin-key" type="password" value="{{pluginkey}}" required>
            <div class="form-text">{{#str}}plugin_key_help, local_softsysvideo{{/str}}</div>
        </div>

        <div class="d-flex gap-2">
            <button type="button" class="btn btn-secondary" id="softsysvideo-test-btn">
                {{#str}}test_connection, local_softsysvideo{{/str}}
            </button>
            <button type="button" class="btn btn-primary d-none" id="softsysvideo-configure-btn">
                {{#str}}configure_bbb, local_softsysvideo{{/str}}
            </button>
        </div>
    </form>

    <div
        id="softsysvideo-status"
        class="mt-3"
        aria-live="polite"
        data-testing-label="{{testinglabel}}"
        data-request-failed-label="{{requestfailedlabel}}"></div>
</div>
